rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwnerUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validIsoDateString(value) {
      return value is string
        && value.size() >= 20
        && value.size() <= 40;
    }

    function validTime(value) {
      return value == null
        || (
          value is string
          && value.size() == 5
          && value.matches('^([01]\\d|2[0-3]):[0-5]\\d$')
        );
    }

    function validColor(value) {
      return value is string
        && value.size() == 7
        && value.matches('^#[0-9A-Fa-f]{6}$');
    }

    function validEvent(eventId) {
      return eventId.size() > 0
        && eventId.size() <= 120
        && request.resource.data.keys().hasOnly([
          'id',
          'event_date',
          'event_type',
          'start_time',
          'end_time',
          'friend_name',
          'memo',
          'reminder_minutes',
          'created_at',
          'updated_at',
          'created_by',
          'creator_color'
        ])
        && request.resource.data.id == eventId
        && request.resource.data.id is string
        && request.resource.data.id.size() > 0
        && request.resource.data.id.size() <= 120
        && request.resource.data.event_date is string
        && request.resource.data.event_date.size() == 10
        && request.resource.data.event_date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && (
          !request.resource.data.keys().hasAny(['event_type'])
          || (
            request.resource.data.event_type is string
            && request.resource.data.event_type in ['game', 'other', 'common']
          )
        )
        && validTime(request.resource.data.start_time)
        && validTime(request.resource.data.end_time)
        && request.resource.data.reminder_minutes is int
        && request.resource.data.reminder_minutes in [0, 5, 10, 30, 60]
        && request.resource.data.friend_name is string
        && request.resource.data.friend_name.size() > 0
        && request.resource.data.friend_name.size() <= 80
        && request.resource.data.memo is string
        && request.resource.data.memo.size() <= 500
        && (
          !request.resource.data.keys().hasAny(['created_by'])
          || (
            request.resource.data.created_by is string
            && request.resource.data.created_by.size() > 0
            && request.resource.data.created_by.size() <= 120
          )
        )
        && (
          !request.resource.data.keys().hasAny(['creator_color'])
          || validColor(request.resource.data.creator_color)
        )
        && validIsoDateString(request.resource.data.created_at)
        && validIsoDateString(request.resource.data.updated_at);
    }

    function memberPath(calendarId, uid) {
      return /databases/$(database)/documents/sharedCalendars/$(calendarId)/members/$(uid);
    }

    function isCalendarMember(calendarId) {
      return signedIn() && exists(memberPath(calendarId, request.auth.uid));
    }

    function currentMemberRole(calendarId) {
      return get(memberPath(calendarId, request.auth.uid)).data.role;
    }

    function canEditCalendar(calendarId) {
      return isCalendarMember(calendarId)
        && currentMemberRole(calendarId) in ['owner', 'editor'];
    }

    function isSharedCalendarOwner(calendarId) {
      return signedIn()
        && exists(/databases/$(database)/documents/sharedCalendars/$(calendarId))
        && get(/databases/$(database)/documents/sharedCalendars/$(calendarId)).data.ownerUid == request.auth.uid;
    }

    function validCalendarCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'name',
          'ownerUid',
          'inviteCode',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.inviteCode is string
        && request.resource.data.inviteCode.size() >= 8
        && request.resource.data.inviteCode.size() <= 40
        && request.resource.data.inviteCode.matches('^[A-Z0-9]+$')
        && validIsoDateString(request.resource.data.createdAt)
        && validIsoDateString(request.resource.data.updatedAt);
    }

    function validMembership(calendarId, userId) {
      return request.resource.data.role in ['owner', 'editor', 'viewer']
        && request.resource.data.joinedAt is string
        && validIsoDateString(request.resource.data.joinedAt)
        && (
          request.resource.data.keys().hasOnly(['role', 'joinedAt'])
          || request.resource.data.keys().hasOnly(['role', 'joinedAt', 'themeColor'])
          || request.resource.data.keys().hasOnly(['role', 'joinedAt', 'inviteCodeUsed'])
          || request.resource.data.keys().hasOnly(['role', 'joinedAt', 'inviteCodeUsed', 'themeColor'])
        )
        && (
          !request.resource.data.keys().hasAny(['themeColor'])
          || validColor(request.resource.data.themeColor)
        )
        && (
          request.resource.data.role == 'owner'
          || (
            request.resource.data.inviteCodeUsed is string
            && exists(/databases/$(database)/documents/inviteCodes/$(request.resource.data.inviteCodeUsed))
            && get(/databases/$(database)/documents/inviteCodes/$(request.resource.data.inviteCodeUsed)).data.calendarId == calendarId
          )
        );
    }

    function validUserMembership(calendarId) {
      return request.resource.data.keys().hasOnly([
          'role',
          'joinedAt',
          'name',
          'inviteCode',
          'themeColor'
        ])
        && request.resource.data.role in ['owner', 'editor', 'viewer']
        && validIsoDateString(request.resource.data.joinedAt)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.inviteCode is string
        && request.resource.data.inviteCode.size() >= 8
        && request.resource.data.inviteCode.size() <= 40
        && request.resource.data.inviteCode.matches('^[A-Z0-9]+$')
        && validColor(request.resource.data.themeColor)
        && exists(memberPath(calendarId, request.auth.uid))
        && get(memberPath(calendarId, request.auth.uid)).data.role == request.resource.data.role;
    }

    match /users/{userId}/events/{eventId} {
      allow read, delete: if isOwnerUser(userId);
      allow create, update: if isOwnerUser(userId) && validEvent(eventId);
    }

    match /users/{userId}/calendarMemberships/{calendarId} {
      allow read: if isOwnerUser(userId);
      allow create: if isOwnerUser(userId) && validUserMembership(calendarId);
      allow update: if (
          isOwnerUser(userId)
          && validUserMembership(calendarId)
        )
        || (
          isOwnerUser(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['themeColor'])
          && validColor(request.resource.data.themeColor)
        )
        || (
          isSharedCalendarOwner(calendarId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name'])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 80
        );
      allow delete: if isOwnerUser(userId) || isSharedCalendarOwner(calendarId);
    }

    match /inviteCodes/{inviteCode} {
      allow get: if signedIn()
        && inviteCode.size() >= 8
        && inviteCode.size() <= 40
        && inviteCode.matches('^[A-Z0-9]+$');

      allow create: if signedIn()
        && inviteCode.size() >= 8
        && inviteCode.size() <= 40
        && inviteCode.matches('^[A-Z0-9]+$')
        && request.resource.data.keys().hasOnly(['calendarId', 'createdAt'])
        && request.resource.data.calendarId is string
        && exists(/databases/$(database)/documents/sharedCalendars/$(request.resource.data.calendarId))
        && get(/databases/$(database)/documents/sharedCalendars/$(request.resource.data.calendarId)).data.ownerUid == request.auth.uid
        && validIsoDateString(request.resource.data.createdAt);

      allow delete: if signedIn()
        && resource.data.calendarId is string
        && isSharedCalendarOwner(resource.data.calendarId);
    }

    match /sharedCalendars/{calendarId} {
      allow read: if isCalendarMember(calendarId);
      allow create: if validCalendarCreate();
      allow update: if isCalendarMember(calendarId)
        && currentMemberRole(calendarId) == 'owner'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'updatedAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && validIsoDateString(request.resource.data.updatedAt);
      allow delete: if isCalendarMember(calendarId) && currentMemberRole(calendarId) == 'owner';

      match /members/{userId} {
        allow read: if isCalendarMember(calendarId);
        allow create: if isOwnerUser(userId)
          && validMembership(calendarId, userId)
          && (
            (
              request.resource.data.role == 'owner'
              && get(/databases/$(database)/documents/sharedCalendars/$(calendarId)).data.ownerUid == request.auth.uid
            )
            || (
              request.resource.data.role == 'editor'
              && request.resource.data.inviteCodeUsed is string
              && get(/databases/$(database)/documents/inviteCodes/$(request.resource.data.inviteCodeUsed)).data.calendarId == calendarId
            )
          );
        allow update: if (
            isOwnerUser(userId)
            && isCalendarMember(calendarId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['themeColor'])
            && validColor(request.resource.data.themeColor)
          )
          || (
            isCalendarMember(calendarId)
            && currentMemberRole(calendarId) == 'owner'
          )
          || (
            isOwnerUser(userId)
            && resource.data.role == 'editor'
            && validMembership(calendarId, userId)
            && request.resource.data.role == 'editor'
            && request.resource.data.inviteCodeUsed is string
            && get(/databases/$(database)/documents/inviteCodes/$(request.resource.data.inviteCodeUsed)).data.calendarId == calendarId
          );
        allow delete: if isCalendarMember(calendarId) && currentMemberRole(calendarId) == 'owner';
      }

      match /events/{eventId} {
        allow read: if isCalendarMember(calendarId);
        allow create: if canEditCalendar(calendarId)
          && validEvent(eventId)
          && (
            !request.resource.data.keys().hasAny(['created_by'])
            || request.resource.data.created_by == request.auth.uid
          );
        allow update: if canEditCalendar(calendarId)
          && validEvent(eventId)
          && (
            !resource.data.keys().hasAny(['created_by'])
            || request.resource.data.created_by == resource.data.created_by
          );
        allow delete: if canEditCalendar(calendarId);
      }
    }
  }
}
